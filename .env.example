# Copy to .env and edit. Everything here is optional; sensible defaults ship
# in utils/config.py.

# --- HTTP binding (dev-server only; production uses gunicorn) ---------------
HOST=0.0.0.0
PORT=8000

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO

# --- Flask mode -------------------------------------------------------------
# "development" relaxes CORS to "*"; anything else locks CORS down.
FLASK_ENV=production

# --- Security ---------------------------------------------------------------
# Required in production. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Comma-separated list of allowed origins for /api/*. Empty in production =
# no cross-origin access. Example:
#   CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# --- Upload / rate limits ---------------------------------------------------
# File upload cap, in megabytes.
MAX_UPLOAD_MB=50

# Flask-Limiter strings. Semicolons separate tiers.
# Default rate for cheap endpoints.
RATE_LIMIT_DEFAULT=100/minute;1000/hour
# Expensive: 3D embed, conformer search, MMFF optimize, bulk similarity.
RATE_LIMIT_EXPENSIVE=10/minute;100/hour
# Bulk uploads (batch_file, *_file endpoints).
RATE_LIMIT_BULK=5/minute;50/hour
